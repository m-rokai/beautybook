# Neon Postgres
# Get these from https://console.neon.tech/app/projects → your project → Connection Details
# Use the Pooled URL for runtime queries; the Unpooled URL is required for Drizzle migrations.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Square — Web Payments SDK + Payments API
# Get these from https://developer.squareup.com/apps → your app
# Use the "Sandbox" tab while testing, then swap to "Production" when ready.
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# Auth.js — admin magic-link sign-in (Google Workspace SMTP relay)
# Generate AUTH_SECRET with: npx auth secret  (writes to .env.local automatically)
AUTH_SECRET=
# Comma-separated allow-list of emails that may sign into /admin.
# Any email not on this list is blocked at the signIn callback.
AUTH_ALLOWED_ADMIN_EMAILS=

# Workspace mailbox used to send magic links. Must have 2-Step Verification on
# and an App Password generated at myaccount.google.com → Security → App passwords.
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
# Display name + address shown in the recipient's inbox.
EMAIL_FROM="Ashley Lacy Aesthetics <bookings@muzeoffice.com>"

NEXT_PUBLIC_APP_URL=http://localhost:3100
