# Neon Postgres
# Get these from https://console.neon.tech/app/projects → your project → Connection Details
# Use the Pooled URL for runtime queries; the Unpooled URL is required for Drizzle migrations.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Square — Web Payments SDK + Payments API
# Get these from https://developer.squareup.com/apps → your app
# Use the "Sandbox" tab while testing, then swap to "Production" when ready.
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

RESEND_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3100
